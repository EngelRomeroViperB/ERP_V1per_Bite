# Supabase (público - seguro para el cliente)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Supabase (secreto - solo servidor)
SUPABASE_SERVICE_ROLE_KEY=

# Edge Functions (configurar en Supabase Dashboard → Settings → Edge Functions)
GEMINI_API_KEY=
# Opcional: override de modelos (prioridad por coma)
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash
SHOPIFY_WEBHOOK_SECRET=

# Notion OAuth (integración pública)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:3000/api/notion/callback

# Web Push (generar con: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu@email.com
